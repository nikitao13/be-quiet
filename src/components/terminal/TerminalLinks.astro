---
interface Link {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  links: Link[];
  prompt?: string;
}

const {
  links,
  prompt = "nikitao13@main:~$",
} = Astro.props;
---

<nav class="terminal-links" aria-label="site links">
  <span class="terminal-links-prompt">{prompt}</span>

  {links.map(({ label, href, external }) => (
    <a
      href={href}
      target={external ? "_blank" : undefined}
      rel={external ? "noopener noreferrer" : undefined}
    >
      {label}
    </a>
  ))}
</nav>

<style>
  .terminal-links {
    display: flex;
    align-items: center;
    gap: clamp(0.35rem, 2vw, 0.75rem);

    width: 100%;
    max-width: 100%;
    padding: var(--terminal-padding-block)
      clamp(0.45rem, 2vw, var(--terminal-padding-inline));

    overflow-x: auto;
    white-space: nowrap;

    font-family: var(--terminal-font);
    font-size: clamp(0.6rem, 2vw, 0.75rem);
    line-height: 1;

    color: var(--color-muted);
    background: var(--terminal-background);
    border: 1px solid var(--terminal-border-color);
    border-radius: var(--terminal-border-radius);
  }

  .terminal-links-prompt {
    color: var(--color-accent-bright);
  }

  .terminal-links a {
    color: var(--color-muted);
  }

  .terminal-links a::before {
    content: "--";
    margin-right: 0.2rem;
    color: var(--terminal-prefix-color);
  }

  .terminal-links a:hover {
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .terminal-links {
      width: fit-content;
      gap: 0.75rem;
      font-size: 0.8rem;
    }

    .terminal-links a:first-of-type {
      margin-left: 0;
    }
  }
</style>