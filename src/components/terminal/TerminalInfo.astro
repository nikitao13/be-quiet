---
interface InfoItem {
  label: string;
  value: string;
  desktopOnly?: boolean;
}

interface Props {
  prompt: string;
  items: InfoItem[];
  ariaLabel?: string;
}

const {
  prompt,
  items,
  ariaLabel = "terminal information",
} = Astro.props;
---

<div class="terminal-info" aria-label={ariaLabel}>
  <span class="terminal-info-prompt">{prompt}</span>

  {
    items.map(({ label, value, desktopOnly }) => (
      <span
        class:list={[
          "terminal-info-data",
          { "terminal-info-desktop": desktopOnly },
        ]}
      >
        {label} {value}
      </span>
    ))
  }
</div>

<style>
  .terminal-info {
    display: flex;
    align-items: center;
    gap: clamp(0.25rem, 1.25vw, 0.5rem);

    width: 100%;
    max-width: 100%;
    padding: var(--terminal-padding-block)
      clamp(0.45rem, 2vw, var(--terminal-padding-inline));

    overflow-x: auto;
    white-space: nowrap;

    font-family: var(--terminal-font);
    font-size: clamp(0.6rem, 2vw, 0.75rem);
    line-height: 1;

    color: var(--color-muted);
    background: var(--terminal-background);
    border: 1px solid var(--terminal-border-color);
    border-radius: var(--terminal-border-radius);
  }

  .terminal-info-prompt {
    color: var(--color-accent-bright);
  }

  .terminal-info-data::before {
    content: "--";
    margin-right: 0.2rem;
    color: var(--terminal-prefix-color);
  }

  .terminal-info-data {
    transition: color var(--motion-duration-fast) var(--motion-easing);
  }

  .terminal-info-data:hover {
    color: var(--color-text);
  }

  .terminal-info-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .terminal-info {
      width: fit-content;
      gap: 0.75rem;
      font-size: 0.69rem;
    }

    .terminal-info-desktop {
      display: inline;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-info-data {
      transition: none;
    }
  }
</style>