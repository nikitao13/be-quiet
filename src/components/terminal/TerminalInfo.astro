---
interface InfoItem {
  label: string;
  value?: string;
  mobileValue?: string;

  labelHref?: string;
  valueHref?: string;

  labelExternal?: boolean;
  valueExternal?: boolean;

  color?: string;
  desktopOnly?: boolean;
}

interface Props {
  prompt: string;
  items: InfoItem[];
  ariaLabel?: string;
  as?: "div" | "nav";
  textSize?: string;
  desktopTextSize?: string;
}

const {
  prompt,
  items,
  ariaLabel = "terminal information",
  as: Element = "div",
  textSize = "clamp(0.6rem, 2vw, 0.75rem)",
  desktopTextSize = "0.69rem",
} = Astro.props;

const getLinkAttributes = (external?: boolean) =>
  external
    ? {
        target: "_blank",
        rel: "noopener noreferrer",
      }
    : {};
---

<Element
  class="terminal-info"
  aria-label={ariaLabel}
  style={{
    "--terminal-info-text-size": textSize,
    "--terminal-info-desktop-text-size": desktopTextSize,
  }}
>
  <span class="terminal-info-prompt">{prompt}</span>

  {
    items.map((item) => {
      const LabelElement = item.labelHref ? "a" : "span";
      const ValueElement = item.valueHref ? "a" : "span";

      return (
        <span
          class:list={[
            "terminal-info-data",
            { "terminal-info-desktop": item.desktopOnly },
          ]}
        >
          <LabelElement
            class="terminal-info-label"
            href={item.labelHref}
            {...getLinkAttributes(item.labelExternal)}
          >
            {item.label}
          </LabelElement>

          {item.value && (
            <>
              {" "}
              <ValueElement
                class="terminal-info-value"
                href={item.valueHref}
                style={{ color: item.color }}
                {...getLinkAttributes(item.valueExternal)}
              >
                {item.mobileValue ? (
                  <>
                    <span class="terminal-info-value-mobile">
                      {item.mobileValue}
                    </span>

                    <span class="terminal-info-value-desktop">
                      {item.value}
                    </span>
                  </>
                ) : (
                  item.value
                )}
              </ValueElement>
            </>
          )}
        </span>
      );
    })
  }
</Element>

<style>
  .terminal-info {
    display: flex;
    align-items: center;
    gap: clamp(0.25rem, 1.25vw, 0.5rem);

    width: 100%;
    max-width: 100%;
    padding: var(--terminal-padding-block)
      clamp(0.45rem, 2vw, var(--terminal-padding-inline));

    overflow-x: auto;
    white-space: nowrap;

    font-family: var(--terminal-font);
    font-size: var(--terminal-info-text-size);
    line-height: 1;

    color: var(--color-muted);
    background: var(--terminal-background);
    border: 1px solid var(--terminal-border-color);
    border-radius: var(--terminal-border-radius);
  }

  .terminal-info-prompt {
    color: var(--color-accent-bright);
  }

  .terminal-info-data {
    transition: var(--color-transition);

    &::before {
      margin-right: 0.2rem;

      color: var(--terminal-prefix-color);
      content: "--";
    }

    &:hover {
      color: var(--color-text);
    }
  }

  .terminal-info-label,
  .terminal-info-value {
    color: inherit;
    text-decoration: none;
  }

  a.terminal-info-label,
  a.terminal-info-value {
    transition: color var(--motion-duration-fast) var(--motion-easing);

    &:hover {
      color: var(--color-text);
    }
  }

  .terminal-info-desktop,
  .terminal-info-value-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .terminal-info {
      width: fit-content;
      gap: 0.75rem;

      font-size: var(--terminal-info-desktop-text-size);
    }

    .terminal-info-desktop,
    .terminal-info-value-desktop {
      display: inline;
    }

    .terminal-info-value-mobile {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    a.terminal-info-label,
    a.terminal-info-value {
      transition: none;
    }
  }
</style>