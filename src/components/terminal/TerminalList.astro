---
import TerminalControls from "@/components/terminal/TerminalControls.astro";

interface Props {
  title: string;
  prompt?: string;
}

const {
  title,
  prompt = "nikitao13@main:~$",
} = Astro.props;
---

<section class="terminal-list" data-terminal-title={title}>
  <div class="terminal-list-header">
    <div class="terminal-list-title">
      <span class="terminal-list-prompt">{prompt}</span>
      <span class="terminal-list-command">cat {title}.txt</span>
    </div>

    <TerminalControls title={title} />
  </div>

  <div class="terminal-list-collapse">
    <div class="terminal-list-content-wrapper">
      <div class="terminal-list-content">
        <slot />
      </div>
    </div>
  </div>
</section>

<style>
  .terminal-list {
    width: 100%;
    max-width: 100%;
    overflow: hidden;

    font-family: var(--terminal-font);
    font-size: clamp(0.6rem, 2vw, 0.75rem);
    line-height: 1.5;

    color: var(--color-muted);
    background: var(--terminal-background);
    border: 1px solid var(--terminal-border-color);
    border-radius: var(--terminal-border-radius);
  }

  .terminal-list-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    padding: var(--terminal-padding-block) var(--terminal-padding-inline);

    white-space: nowrap;
    border-bottom: 1px solid var(--terminal-border-color);

    transition:
      border-color var(--motion-duration-base) var(--motion-easing);
  }

  .terminal-list.is-minimised .terminal-list-header {
    border-bottom-color: transparent;
  }

  .terminal-list-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    min-width: 0;
    overflow: hidden;
  }

  .terminal-list-prompt {
    color: var(--color-accent-bright);
  }

  .terminal-list-command {
    overflow: hidden;
    color: var(--color-muted);
    text-overflow: ellipsis;
  }

  .terminal-list-collapse {
    display: grid;
    grid-template-rows: 1fr;

    visibility: visible;
    opacity: 1;

    transition:
      grid-template-rows var(--motion-duration-layout) var(--motion-easing),
      opacity var(--motion-duration-fast) var(--motion-easing),
      visibility 0s;
  }

  .terminal-list.is-minimised .terminal-list-collapse {
    grid-template-rows: 0fr;

    visibility: hidden;
    opacity: 0;

    transition:
      grid-template-rows var(--motion-duration-layout) var(--motion-easing),
      opacity var(--motion-duration-fast) var(--motion-easing),
      visibility 0s var(--motion-duration-layout);
  }

  .terminal-list-content-wrapper {
    min-height: 0;
    overflow: hidden;
  }

  .terminal-list-content {
    padding: 0.55rem var(--terminal-padding-inline) 0.65rem;
  }

  .terminal-list-content :global(ul) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;

    margin: 0;
    padding: 0;

    list-style: none;
  }

  .terminal-list-content :global(li) {
    position: relative;
    padding-left: 1.4rem;
  }

  .terminal-list-content :global(li::before) {
    content: "--";
    position: absolute;
    left: 0;

    color: var(--terminal-prefix-color);
  }

  .terminal-list-content :global(a) {
    color: var(--color-muted);
  }

  .terminal-list-content :global(a:hover) {
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .terminal-list {
      width: 100%;
      min-width: 0;
      font-size: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-list-header,
    .terminal-list-collapse {
      transition: none;
    }
  }
</style>