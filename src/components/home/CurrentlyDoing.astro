---
import TerminalList from "@/components/home/TerminalList.astro";
---

<div class="terminal-lists">
  <TerminalList title="playing">
    <ul>
      <li><a href="https://store.steampowered.com/app/3489700/Stellar_Blade/" target="_blank">stellar blade</a></li>
			<li><a href="https://store.steampowered.com/app/1364780/Street_Fighter_6/" target="_blank">street fighter 6</a></li>
      <li><a href="https://store.steampowered.com/app/1384160/GUILTY_GEAR_STRIVE/" target="_blank">guilty gear strive</a></li>
      <li><a href="https://store.steampowered.com/app/2273430/BlazBlue_Entropy_Effect/" target="_blank">blazblue entropy effect</a></li>
      <li><a href="https://oldschool.runescape.com/" target="_blank">old school runescape</a></li>
    </ul>
  </TerminalList>

  <TerminalList title="watching">
    <ul>
      <li><a href="https://www.imdb.com/title/tt2356777/" target="_blank">true detective</a></li>
      <li><a href="https://www.imdb.com/title/tt12590266/" target="_blank">cyberpunk: edgerunners</a></li>
			<li><a href="https://www.imdb.com/title/tt3114390/" target="_blank">kill la kill</a></li>
      <li><a href="https://www.imdb.com/title/tt0994314/" target="_blank">code geass</a></li>
    </ul>
</TerminalList>

  <TerminalList title="listening">
  <ul>
    <li>deftones</li>
    <li>tool</li>
    <li>parkway drive</li>
    <li>bring me the horizon</li>
  </ul>
</TerminalList>

  <TerminalList title="reading">
    <ul>
		  <li>java: a beginners guide</li>
      <li>algorithms to live by</li>
      <li>the order of time</li>
    </ul>
  </TerminalList>
</div>

<style>
  .terminal-lists {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    width: 100%;
  }

  .terminal-lists :global(li:hover) {
    color: var(--color-text);
  }

  .terminal-lists :global(a) {
    cursor: default;
  }
</style>