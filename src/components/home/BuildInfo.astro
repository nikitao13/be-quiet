---
import TerminalInfo from "@/components/terminal/TerminalInfo.astro";
import { getBuildData } from "@/lib/build";

const buildData = getBuildData();

const items = [
  {
    label: "astro",
    value: buildData.astro,
  },
  {
    label: "branch",
    value: buildData.branch,
  },
  {
    label: "commit",
    value: buildData.commit,
  },
  {
    label: "deployed",
    value: buildData.platform,
    desktopOnly: true,
  },
  {
    label: "built",
    value: buildData.built,
    desktopOnly: true,
  },
];
---

<TerminalInfo
  prompt="build@info:~$"
  ariaLabel="build information"
  items={items}
/>