---
import BuildInfo from "@/components/home/BuildInfo.astro";
import Links from "@/components/home/Links.astro";
import SystemInfo from "@/components/home/SystemInfo.astro";
---

<section class="home-hero">
  <h1 class="blog-title">
    nikita o'keeffe<span class="accent">; </span>
    <br class="mobile-break" />
    a static website<span class="accent">.</span>
  </h1>

  <div class="home-terminal-stack">
    <BuildInfo />
    <SystemInfo />
    <Links />
  </div>
</section>

<style>
  .home-hero {
    display: flex;
    flex-direction: column;
    gap: var(--home-hero-gap);
  }

  .home-terminal-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--home-section-gap);
  }

  .mobile-break {
    display: none;
  }

  @media (max-width: 600px) {
    .mobile-break {
      display: block;
    }
  }
</style>