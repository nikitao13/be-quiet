---
import BuildInfo from "@/components/home/BuildInfo.astro";
import Links from "@/components/home/Links.astro";
---

<section class="home-hero">
  <h1 class="blog-title">
    nikita o'keeffe<span class="red">;</span> a personal/dev website<span
      class="red">.</span
    >
  </h1>

  <div class="home-terminal-stack">
    <BuildInfo />
    <Links />
  </div>
</section>

<style>
  .home-hero {
    display: flex;
    flex-direction: column;
    gap: var(--home-hero-gap);
  }

  .home-terminal-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--home-section-gap);
  }
</style>