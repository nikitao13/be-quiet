---
import { getLatestBlogPost } from "@/lib/blog";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Post from "@/components/blog/Post.astro";
import PostFooter from "@/components/blog/PostFooter.astro";

const latestPost = await getLatestBlogPost();
---

<BaseLayout title={latestPost.data.title}>
  <Post post={latestPost} />
  <PostFooter postId={latestPost.id} />
</BaseLayout>